# --- API Keys ---
OPENAI_API_KEY=YOUR_OPENAI_API_KEY_HERE
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE

# --- Meshtastic Connection ---
MESHTASTIC_CONNECTION_TYPE=serial
MESHTASTIC_DEVICE_SPECIFIER=
# For TCP: MESHTASTIC_DEVICE_SPECIFIER=10.10.100.209

# --- AI Settings ---
DEFAULT_AI_SERVICE=openai

# --- Matrix Bridge (optional) ---
# Set MATRIX_ENABLED=true to bridge mesh messages to Matrix rooms
MATRIX_ENABLED=false
MATRIX_HOMESERVER=https://matrix.org
MATRIX_USERNAME=@your-bot:matrix.org
MATRIX_PASSWORD=your-bot-password
# Comma-separated list of Matrix user IDs to auto-invite to bridge rooms
MATRIX_INVITE_USERS=@your-account:matrix.org
